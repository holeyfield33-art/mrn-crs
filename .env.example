# MRN Constrained Reasoning System – Environment Variables
# Copy to .env and customise for your deployment.

# ----- Service URLs -----
ALETHEIA_URL=http://aletheia:8300
GEOMETRIC_URL=http://geometric:8200
MNEME_URL=http://mneme:8100

# ----- Authentication -----
# Comma-separated Bearer tokens. Leave empty to disable auth.
CRS_API_KEYS=

# ----- Rate limiting -----
CRS_RATE_LIMIT_PER_MINUTE=60
# Redis URL for distributed rate limiting (leave empty for in-memory)
REDIS_URL=

# ----- Self-healing -----
ENABLE_SELF_HEALING=true
SELF_HEAL_INTERVAL_SECONDS=15
SELF_HEAL_DRIFT_THRESHOLD=0.5
SELF_HEAL_HEALTHY_R_MIN=0.57
SELF_HEAL_HEALTHY_R_MAX=0.59
SELF_HEAL_HEALTHY_SHI_MIN=0.8
SELF_HEAL_MIN_MEMORIES=10

# Drift level thresholds
SELF_HEAL_LEVEL_LOW=0.02
SELF_HEAL_LEVEL_MEDIUM=0.05
SELF_HEAL_LEVEL_HIGH=0.10

# Human escalation
SELF_HEAL_ESCALATION_WEBHOOK=
SELF_HEAL_ESCALATION_FILE=escalations.jsonl

# Healing history
HEALING_HISTORY_DB=healing_history.db

# Sampling temperature (initial; adjusted by self-healing)
SAMPLING_TEMPERATURE=0.7

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Autonomous mode (unconstrained) -----
ENABLE_HUMAN_GATES=false
AUTONOMOUS_MODE=true
FREEZE_ON_CRITICAL=true
